	"name": "@sindresorhus/is",
	"version": "0.7.0",
	"description": "Type check values: `is.string('🦄') //=> true`",
	"license": "MIT",
	"repository": "sindresorhus/is",
	"author": {
		"name": "Sindre Sorhus",
		"email": "sindresorhus@gmail.com",
