		st.equal((/a/g).flags, 'g', '(/a/g).flags !== "g"');
		st.equal((/a/gmi).flags, 'gim', '(/a/gmi).flags !== "gim"');
		st.equal(new RegExp('a', 'gmi').flags, 'gim', 'new RegExp("a", "gmi").flags !== "gim"');
		st.equal((/a/).flags, '', '(/a/).flags !== ""');
